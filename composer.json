{
    "name": "unopim/mcp",
    "description": "UnoPim Model Context Protocol (MCP) bridge for AI-powered catalog interaction.",
    "type": "laravel-library",
    "keywords": [
        "mcp",
        "unopim",
        "laravel",
        "ai",
        "pim",
        "security",
        "automation"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Webkul",
            "email": "support@webkul.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^12.41.1|^13.0",
        "illuminate/contracts": "^12.41.1|^13.0",
        "illuminate/http": "^12.41.1|^13.0",
        "illuminate/support": "^12.41.1|^13.0",
        "illuminate/validation": "^12.41.1|^13.0",
        "konecty/concord": "^1.12",
        "laravel/mcp": "^0.6.0",
        "laravel/passport": "^11.0|^12.0",
        "symfony/yaml": "^7.0",
        "symfony/process": "^7.0"
    },
    "require-dev": {
        "pestphp/pest": "^2.0|^3.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Webkul\\MCP\\": "packages/Webkul/MCP/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webkul\\MCP\\Tests\\": "packages/Webkul/MCP/tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webkul\\MCP\\Providers\\MCPServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}